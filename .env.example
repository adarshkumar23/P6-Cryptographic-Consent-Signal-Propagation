# Satellite's own database — NEVER core's production database.
DATABASE_URL=postgresql+psycopg2://p6:p6@localhost:5433/p6_consent_propagation

# Satellite-local key-encryption-key used to encrypt each org's Ed25519
# private key at rest. Architecturally separate from core's secrets —
# see ASSUMPTIONS.md. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SATELLITE_KEK=

# Core's read-only export endpoint this satellite polls for
# consent_records and registered_processors. See ASSUMPTIONS.md —
# this contract is assumed, not verified against a real core clone.
CORE_BASE_URL=http://localhost:8000
CORE_API_KEY=

# Retry/escalation timing (seconds) — must match PATENT.md Component 4.
RETRY_BACKOFF_SECONDS=30,120,300
ESCALATION_NON_ACK_HOURS=48
